---
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import EmailCapture from '../components/EmailCapture.astro';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Meridian',
  url: import.meta.env.PUBLIC_SITE_URL || 'https://meridian.coffee',
  description: 'Coffee, calibrated.',
};
---

<Base
  title="Meridian | Specialty Coffee — Coming Soon"
  description="Meridian specialty coffee is launching soon. Join the list for early access, founding-member pricing, and our first roast drop."
  structuredData={[websiteSchema]}
>
  <header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-6 sm:px-10">
    <a href="/" class="font-display text-lg tracking-tight">Meridian</a>
    <nav class="flex items-center gap-6">
      <a href="#story" class="hidden text-sm transition hover:opacity-70 sm:inline" style="color: var(--muted);">Our story</a>
      <a href="/about" class="hidden text-sm transition hover:opacity-70 sm:inline" style="color: var(--muted);">About</a>
      <ThemeToggle />
    </nav>
  </header>

  <main>
    <!-- HERO -->
    <section class="mx-auto grid max-w-6xl gap-12 px-6 pb-20 pt-8 sm:px-10 lg:grid-cols-[1.1fr_0.9fr] lg:gap-8 lg:pb-32 lg:pt-16">
      <div class="flex flex-col justify-center">
        <p class="mb-5 text-xs font-medium uppercase tracking-[0.2em]" style="color: var(--accent);">Launching 2026</p>
        <h1 class="font-display text-5xl leading-[0.98] tracking-tight sm:text-6xl lg:text-7xl">
          Meridian is<br /><em class="not-italic" style="color: var(--accent);">almost</em> here
        </h1>
        <p class="mt-6 max-w-md text-lg leading-relaxed" style="color: var(--muted);">
          Specialty coffee for people who treat their morning cup as a craft ritual — sourced with precision, roasted with intent. Coffee, calibrated.
        </p>
        <div class="mt-10">
          <EmailCapture id="hero-signup" ctaLabel="Join the list" />
          <p class="mt-3 text-xs" style="color: var(--muted);">
            Early access, founding-member pricing, and first look at our debut roast. No spam, ever.
          </p>
        </div>
      </div>

      <div class="relative order-first lg:order-last">
        <div class="aspect-[4/5] w-full overflow-hidden border" style="border-color: var(--line);">
          <img
            src="https://images.unsplash.com/photo-1447933601403-0c6688de566e?q=80&w=1200&auto=format&fit=crop"
            alt="Freshly roasted single-origin coffee beans cooling after roasting"
            class="h-full w-full object-cover grayscale-[15%]"
            loading="eager"
          />
        </div>
        <div class="absolute -bottom-6 -left-6 hidden max-w-[220px] border bg-[var(--paper)] p-5 shadow-sm sm:block" style="border-color: var(--line);">
          <p class="font-display text-2xl" style="color: var(--accent);">08:42</p>
          <p class="mt-1 text-xs" style="color: var(--muted);">Roast log — the point our first origin hit peak development.</p>
        </div>
      </div>
    </section>

    <!-- STORY TEASER -->
    <section id="story" class="border-t" style="border-color: var(--line);">
      <div class="mx-auto grid max-w-6xl gap-10 px-6 py-20 sm:px-10 lg:grid-cols-2 lg:gap-16 lg:py-28">
        <div>
          <p class="text-xs font-medium uppercase tracking-[0.2em]" style="color: var(--accent);">Why Meridian</p>
          <h2 class="font-display mt-4 text-3xl leading-[1.02] tracking-tight sm:text-4xl">
            A cup calibrated, not guessed at
          </h2>
        </div>
        <div class="max-w-xl">
          <p class="text-base leading-relaxed" style="color: var(--muted);">
            Most coffee gets roasted to a schedule. Ours gets roasted to a curve — logged, tasted, and adjusted lot by lot until the profile matches what the farm actually grew. We buy direct from three growing regions, pay above certification premiums, and roast in small batches so nothing sits on a shelf losing its edge.
          </p>
          <p class="mt-4 text-base leading-relaxed" style="color: var(--muted);">
            We're not open yet. We're finishing the last few roast curves and locking in our founding lineup before we ship a single bag.
          </p>
          <a
            href="/about"
            class="mt-6 inline-flex items-center gap-2 text-sm font-medium transition hover:gap-3"
            style="color: var(--accent);"
          >
            Read the full story
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- WHAT TO EXPECT -->
    <section class="border-t" style="border-color: var(--line);">
      <div class="mx-auto max-w-6xl px-6 py-20 sm:px-10 lg:py-28">
        <h2 class="font-display max-w-lg text-3xl leading-[1.02] tracking-tight sm:text-4xl">What's coming with launch</h2>
        <div class="mt-12 grid gap-10 border-t sm:grid-cols-3" style="border-color: var(--line);">
          <div class="border-t-2 pt-6" style="border-color: var(--accent);">
            <p class="font-display text-2xl">01</p>
            <h3 class="mt-3 text-base font-medium">Three founding origins</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color: var(--muted);">Ethiopia, Colombia, and Sumatra lots, each roasted to its own logged curve.</p>
          </div>
          <div class="border-t-2 pt-6" style="border-color: var(--accent);">
            <p class="font-display text-2xl">02</p>
            <h3 class="mt-3 text-base font-medium">Founding-member pricing</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color: var(--muted);">List members lock in launch pricing before it goes to the public.</p>
          </div>
          <div class="border-t-2 pt-6" style="border-color: var(--accent);">
            <p class="font-display text-2xl">03</p>
            <h3 class="mt-3 text-base font-medium">Roast-day shipping</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color: var(--muted);">Bags ship within 48 hours of roasting — never off a warehouse shelf.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="border-t" style="border-color: var(--line);">
      <div class="mx-auto max-w-3xl px-6 py-20 text-center sm:px-10 lg:py-28">
        <h2 class="font-display text-3xl leading-[1.02] tracking-tight sm:text-4xl">Be first to know when we open the doors</h2>
        <p class="mx-auto mt-4 max-w-md text-base leading-relaxed" style="color: var(--muted);">
          One email when we launch. That's it.
        </p>
        <div class="mt-8 flex justify-center">
          <EmailCapture id="footer-signup" ctaLabel="Join the list" />
        </div>
      </div>
    </section>
  </main>

  <footer class="border-t" style="border-color: var(--line);">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-10 text-sm sm:flex-row sm:px-10" style="color: var(--muted);">
      <p class="font-display text-base" style="color: var(--ink);">Meridian</p>
      <nav class="flex gap-6">
        <a href="/" class="transition hover:opacity-70">Home</a>
        <a href="/about" class="transition hover:opacity-70">About</a>
        <a href="/thanks" class="transition hover:opacity-70">Thanks</a>
      </nav>
      <p>&copy; 2026 Meridian Coffee. All rights reserved.</p>
    </div>
  </footer>
</Base>
